#!/bin/sh
set -eu

log() {
    if command -v systemd-cat >/dev/null 2>&1; then
        printf '%s\n' "$*" | systemd-cat -t lenovo-vantage-charge-refresh
    else
        logger -t lenovo-vantage-charge-refresh -- "$*"
    fi
}

bat="$(find /sys/class/power_supply -maxdepth 1 -name 'BAT*' | sort | head -n 1)"
[ -n "$bat" ] || exit 0
[ -r "$bat/charge_types" ] || exit 0

charge_types="$(cat "$bat/charge_types")"

case "$charge_types" in
    *"[Long_Life]"*)
        target="Long_Life"
        ;;
    *"[Standard]"*)
        target="Standard"
        ;;
    *)
        log "unknown charge_types state: $charge_types"
        exit 0
        ;;
esac

if printf '%s\n' "$target" > "$bat/charge_types"; then
    log "re-applied charge mode: $target"
else
    log "failed to re-apply charge mode: $target"
    exit 1
fi

# Lenovo's Windows plugin reacts to power-change events. A short second write
# makes Linux-side AC/USB-C event races less likely without changing policy.
sleep 1
printf '%s\n' "$target" > "$bat/charge_types" 2>/dev/null || true
